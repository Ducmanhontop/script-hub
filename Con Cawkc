<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Script Hub</title>
  <style>
    body {
      background: #0f172a;
      color: white;
      font-family: monospace;
      margin: 0;
    }
    .container {
      max-width: 600px;
      margin: auto;
      padding: 20px;
    }
    .card {
      background: #1e293b;
      padding: 15px;
      border-radius: 12px;
      margin-bottom: 20px;
    }
    button {
      background: #7c3aed;
      border: none;
      padding: 10px;
      color: white;
      border-radius: 8px;
      cursor: pointer;
    }
    iframe {
      width: 100%;
      border-radius: 10px;
    }
    pre {
      background: #020617;
      padding: 10px;
      border-radius: 10px;
      overflow-x: auto;
    }
  </style>
</head>

<body>
<div class="container">

  <h1>🔥 Script Hub</h1>

  <div class="card">
    <iframe height="200" src="https://www.youtube.com/embed/VIDEO_ID"></iframe>

    <h2>Dead Rails Auto Farm</h2>
    <p>Nhớ tham gia Discord!</p>

    <button onclick="copyScript()">📋 Copy Script</button>

    <pre id="script">
loadstring(game:HttpGet("https://raw.githubusercontent.com/yourlink/script.lua"))()
    </pre>

    <br>
    <a href="https://discord.gg/yourlink">
      <button>💬 Discord</button>
    </a>

  </div>

</div>

<script>
function copyScript() {
  let text = document.getElementById("script").innerText;
  navigator.clipboard.writeText(text);
  alert("Đã copy script!");
}
</script>

</body>
</html>
